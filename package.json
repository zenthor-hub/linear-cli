{
  "name": "@zenthor-hub/linear-cli",
  "version": "0.1.2",
  "description": "Unofficial community CLI for Linear issue workflows and admin operations. Not affiliated with Linear.",
  "keywords": [
    "agents",
    "cli",
    "graphql",
    "linear",
    "oauth"
  ],
  "homepage": "https://github.com/zenthor-hub/linear-cli#readme",
  "bugs": {
    "url": "https://github.com/zenthor-hub/linear-cli/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenthor-hub/linear-cli.git"
  },
  "bin": {
    "linear": "dist/linear.js",
    "linear-admin": "dist/admin.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && esbuild src/linear.ts src/admin.ts --bundle --packages=external --platform=node --target=node22 --format=esm --outdir=dist",
    "linear": "tsx src/linear.ts",
    "linear-admin": "tsx src/admin.ts",
    "oxlint:check": "oxlint --max-warnings=0 . --ignore-path .oxlintignore",
    "oxlint:fix": "oxlint --fix . --ignore-path .oxlintignore",
    "oxfmt:check": "oxfmt --check . --ignore-path .oxfmtignore",
    "oxfmt:fix": "oxfmt --write . --ignore-path .oxfmtignore",
    "prepack": "bun run build",
    "smoke:global-install": "bun run build && bash scripts/smoke-global-install.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "bun run oxlint:check && bun run typecheck && bun run oxfmt:check && bun run test && bun run smoke:global-install"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "graphql": "^17.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.70.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14"
}
