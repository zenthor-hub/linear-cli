{
  "name": "@zenthor-hub/linear-cli",
  "version": "0.1.0",
  "description": "Linear CLI entrypoints for agent-safe issue workflows and administrative operations.",
  "keywords": [
    "agents",
    "cli",
    "graphql",
    "linear",
    "oauth"
  ],
  "homepage": "https://github.com/zenthor-hub/linear-cli#readme",
  "bugs": {
    "url": "https://github.com/zenthor-hub/linear-cli/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenthor-hub/linear-cli.git"
  },
  "bin": {
    "linear": "./dist/linear.js",
    "linear-admin": "./dist/admin.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && esbuild src/linear.ts src/admin.ts --bundle --packages=external --platform=node --target=node20 --format=esm --outdir=dist",
    "linear": "tsx src/linear.ts",
    "linear-admin": "tsx src/admin.ts",
    "oxlint:check": "oxlint --max-warnings=0 . --ignore-path .oxlintignore",
    "oxlint:fix": "oxlint --fix . --ignore-path .oxlintignore",
    "oxfmt:check": "oxfmt --check . --ignore-path .oxfmtignore",
    "oxfmt:fix": "oxfmt --write . --ignore-path .oxfmtignore",
    "prepack": "npm run build",
    "smoke:global-install": "npm run build && bash scripts/smoke-global-install.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run oxlint:check && npm run typecheck && npm run oxfmt:check && npm test && npm run smoke:global-install"
  },
  "dependencies": {
    "@linear/sdk": "^39.0.0",
    "commander": "^12.1.0",
    "graphql": "^16.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
