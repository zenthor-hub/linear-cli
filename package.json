{
  "name": "linear-cli",
  "version": "0.1.0",
  "description": "Linear CLI entrypoints for agent-safe issue workflows and administrative operations.",
  "bin": {
    "linear": "./src/linear.ts",
    "linear-admin": "./src/admin.ts"
  },
  "type": "module",
  "scripts": {
    "linear": "bun run src/linear.ts",
    "linear-admin": "bun run src/admin.ts",
    "oxlint:check": "oxlint --max-warnings=0 . --ignore-path .oxlintignore",
    "oxlint:fix": "oxlint --fix . --ignore-path .oxlintignore",
    "oxfmt:check": "oxfmt --check . --ignore-path .oxfmtignore",
    "oxfmt:fix": "oxfmt --write . --ignore-path .oxfmtignore",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "verify": "bun run oxlint:check && bun run typecheck && bun run oxfmt:check && bun test"
  },
  "dependencies": {
    "@linear/sdk": "^39.0.0",
    "commander": "^12.1.0",
    "graphql": "^16.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^5.6.0"
  }
}
