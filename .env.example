# Provide EXACTLY ONE request credential. Setting both is an error.

# Personal API key (sent as: Authorization: <key>)
# LINEAR_API_KEY=lin_api_...

# OAuth2 access token (sent as: Authorization: Bearer <token>)
# LINEAR_ACCESS_TOKEN=...

# Forward-looking only. Not consumed in Phase 1; reserved for a future
# client-credentials / OAuth flow (see implementation.md Phase 4).
# LINEAR_CLIENT_ID=...
# LINEAR_CLIENT_SECRET=...

# Optional. When set, each APPLIED mutation appends a redacted JSONL audit
# record to this file. Dry-runs are never logged.
# LINEAR_ADMIN_AUDIT_LOG=./linear-admin-audit.jsonl
