# Provide EXACTLY ONE request credential via env. Setting both is an error.
# Alternatively, run `linear auth login` to store OAuth credentials locally.

# Personal API key (sent as: Authorization: <key>)
# LINEAR_API_KEY=lin_api_...

# OAuth2 access token (sent as: Authorization: Bearer <token>)
# LINEAR_ACCESS_TOKEN=...

# OAuth application (required for `linear auth login`)
# Create at https://linear.app/settings/api/applications/new
# Register redirect URI: http://127.0.0.1:8787/callback
# LINEAR_CLIENT_ID=...
# LINEAR_CLIENT_SECRET=...
# LINEAR_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/callback
# LINEAR_OAUTH_SCOPE=read,write

# Optional override for stored OAuth session file (default ~/.config/linear-cli/credentials.json)
# LINEAR_CREDENTIALS_FILE=...

# Optional named credential profile (stored separately under ~/.config/linear-cli/profiles).
# Do not combine with LINEAR_API_KEY, LINEAR_ACCESS_TOKEN, or LINEAR_CREDENTIALS_FILE.
# LINEAR_PROFILE=client-a

# Headless client-credentials grant (CI/server use; enable on the OAuth app)
# LINEAR_OAUTH_GRANT=client_credentials
# LINEAR_OAUTH_SCOPE=read,admin

# Optional. When set, each APPLIED mutation appends a redacted JSONL audit
# record to this file. Dry-runs are never logged.
# LINEAR_ADMIN_AUDIT_LOG=./linear-admin-audit.jsonl
